{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "csharpier-format-staged",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [ "csharpier", "format", "${staged}" ],
         "include": [ "**/*.cs" ]
      },
      {
         "name": "no-local-paths",
         "group": "pre-commit",
         "command": "powershell",
         "args": [ "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "tools/check-no-local-paths.ps1", "-Staged" ]
      }
   ]
}
