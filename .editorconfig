root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml,json,md}]
indent_size = 2
charset = utf-8

[*.ps1]
end_of_line = crlf

[*.cs]
# フォーマット系ルールは CSharpier に完全委譲(二重整形防止)
dotnet_diagnostic.IDE0055.severity = none

# --- Roslynator 恒久 disable(理由付き) ---
# WinForms UI スレッド前提のためライブラリ側 ConfigureAwait 強制は不要
dotnet_diagnostic.RCS1090.severity = none
# バイナリ演算子の改行位置は CSharpier に完全委譲
dotnet_diagnostic.RCS1029.severity = none

# --- CA(ビルトイン)恒久 disable(理由付き) ---
# CA1707(アンダースコア命名) を disable する主因:
#   - テストメソッド命名 xUnit 慣例 `Method_Scenario_Expected` (最多発)
#   - P/Invoke 定数 Win32 API 名 (WM_* / UiaRootObjectId など・ミラー命名)
#   - プライベートフィールド `_field` プレフィックス
#     (既定 scope=public では未検出だが将来 api_surface 拡張時のため明記)
# narrowing 不採用:
#   naming rule は IDE analyzer 側のみ効き CA analyzer には無効(技術的に不可能)
#   `[SuppressMessage]` 個別付与も 800+ 件で非現実的
dotnet_diagnostic.CA1707.severity = none

# CA1716(仮想メンバー/インターフェースの引数・メンバー名を予約語と重ねない) を disable する主因:
#   - 検出対象は「他言語(主に VB.NET)から override/implement しづらくなる」ケース
#     (例: 引数名 end / メソッド名 Error は VB.NET 予約語と競合)
#   - yEdit は C# 単独プロジェクトで VB.NET 相互運用の予定なし=実害ゼロ
#   - 既存の意味論的に自然な命名(IUiaTextHost.SetSelection の end / IUserPrompt.Error)を
#     `endInclusive` / `ShowError` 等へ改名すると内部呼び出しの読みやすさが損なわれる
dotnet_diagnostic.CA1716.severity = none

# CA1711(型名に Enum / Delegate / Attribute / Flag などの suffix を付けない) を disable する主因:
#   - yEdit.Core.Editing.ImeAttribute は IMM32 GCS_COMPATTR (Composition Attribute) の
#     属性バイト定数群を保持する static class=IME 属性ドメイン用語としての "Attribute" が正
#   - 誤解(System.Attribute 派生と誤読される)を招く命名でも rename(例: ImeAttr / ImeCharAttribute)
#     は既存 public API 破壊で見合わない
#   - 将来 CA1711 対象の追加型が出た場合の判断は case-by-case でこの disable の再検討を含める
dotnet_diagnostic.CA1711.severity = none

# --- SonarAnalyzer 恒久 disable / 降格(理由付き) ---
# TODO/FIXME は docs/plans への申し送りとの併用で残したい
dotnet_diagnostic.S1135.severity = none
# コメントアウトされたコードは履歴用に一時的に残す慣行がある
dotnet_diagnostic.S125.severity = suggestion

# S101(型名 PascalCase 命名規約違反) を disable する主因:
#   - src/yEdit.Editor/NativeMethods.cs の POINT / RECT / LOGFONT / CANDIDATEFORM は
#     Win32 API 構造体(POINT/RECT/LOGFONT/CANDIDATEFORM)のミラー命名で
#     interop 上で SDK ヘッダ名との 1:1 対応を保つのが慣例
#   - rename すると Marshal 側の struct layout 認識には影響しないが、
#     ヘッダとの grep 対応が失われて interop 保守性が低下する
#   - PR3 で CA1707(アンダースコア命名) を P/Invoke 定数の Win32 ミラー命名
#     (WM_* / UiaRootObjectId 等) 理由で恒久 disable した precedent と同旨
dotnet_diagnostic.S101.severity = none

# S127(for ループ内で counter を意図的に変更) を disable する主因:
#   - src/yEdit.Core/Buffer/TextBufferBuilder.cs の UTF-8 decode で
#     `for (int off = 0; off < len;) { …; off += step; }` の可変ステップループが
#     マルチバイト境界処理の基本パターン(1〜4 byte を都度加算)
#   - src/yEdit.Editor/EditorControl.cs の禁則処理でも同型の可変ステップ加算
#     (grapheme cluster / surrogate pair を跨いだ前後移動)が正当ユースケース
#   - while ループへの機械変換は初期化/継続条件/更新式の 3 点セットを
#     散逸させ、ループ不変条件の可読性を落とす
dotnet_diagnostic.S127.severity = none

# S1199(ネストした局所スコープブロック) を disable する主因:
#   - src/yEdit.Core/Search/SnapshotSearcher.cs や tests/yEdit.Editor.Smoke/GdiBench.cs で
#     `{ … }` 局所スコープブロックを用いて一時変数の寿命を明示的に区切る
#     C# の正当慣用句(using ブロックの外でも同種の隔離目的で使う)
#   - method 抽出すると 1 箇所からのみ呼ばれる helper が乱立して読解負荷が増す
#   - inline 展開しても意味は等価だが、変数スコープの縮小が可視化されなくなり
#     `var` 再定義や誤参照のリスクが上がる
dotnet_diagnostic.S1199.severity = none

# S3358(3 段以上の入れ子 ternary) を disable する主因:
#   - src/yEdit.Core/Buffer/TextChunk.cs / TextBufferBuilder.cs の UTF-8 decode で
#     `b < 0x80 ? 1 : b < 0xC0 ? … : b < 0xE0 ? … : …` のように byte 範囲から
#     続きバイト数を引くルックアップテーブル型 3-way chained ternary が定常パターン
#   - src/yEdit.App/MainForm.cs (accesskey 選択) / CsvController.cs (clamp) 等でも
#     連続する範囲判定を短く畳む慣例
#   - if/else if/else へ機械展開すると本体 1 行の代入が 4〜6 行に膨らみ、
#     lookup table としての一覧性が失われる
dotnet_diagnostic.S3358.severity = none

# 追加 disable が必要になれば以下に追記(理由コメント必須)

# --- テストコード限定 disable(理由付き) ---
# tests 配下のみに適用。プロダクションコードには CA ルール本則を維持する。
[tests/**/*.cs]
# CA1051(公開インスタンスフィールド禁止) を tests 限定で disable する主因:
#   - Fake クラス(tests/*/Fakes/*.cs) が観測用に public field を露出する慣例
#     (例: FakeBackupWriter.DisposeCount / DeleteAllCount 等)
#   - property 化するとテスト側で `fake.Count++` が書けなくなり ceremony が増える
#   - 破壊的変更ではない(テスト内部の可視性契約であって外部 API ではない)
dotnet_diagnostic.CA1051.severity = none
# CA1861(定数配列引数を static readonly へ) を tests 限定で disable する主因:
#   - `Assert.Equal(new[] { ... }, actual)` のような inline test data が xUnit 慣例
#   - 各 test method 用に static readonly field を extract すると可読性が犠牲になる
#   - test は 1 回のみ実行される=allocation 削減のパフォーマンス便益が実質ゼロ
dotnet_diagnostic.CA1861.severity = none
# S927(パラメータ名一致=override/interface impl のパラメータを宣言側と揃える)
# を tests 限定で disable する主因:
#   - テスト内 nested `Host` クラス(TextProviderImplV2Tests.Host /
#     TextRangeProviderV2Tests.Host)が IUiaTextHost を実装する際に短縮
#     パラメータ名(s/e/o/l 等)を慣用しており、interface 側の
#     長い記述用名(startOffset/endOffset 等)へ機械 rename すると
#     assertion 呼出しの可読性が落ちる
#   - test は 1 対 1 の観測が主目的で、interface 契約の忠実さは production 側で
#     検査済み(S927 src 側は Task C-8 で個別修正)
dotnet_diagnostic.S927.severity = none
# S1215(GC.Collect の意図的呼出) を tests 限定で disable する主因:
#   - Smoke bench harness の baseline 測定パス(tests/yEdit.Editor.Smoke/Program.cs
#     の --bench-save 分岐)で GC.Collect() を意図的に呼び出す
#   - production コードでは detect したい bug indicator なので src 側は
#     警告のまま残す
dotnet_diagnostic.S1215.severity = none
